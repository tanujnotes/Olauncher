<?xml version="1.0" encoding="utf-8"?>
<!--
  Niagara Launcher 風 ホーム画面レイアウト
  デザインコンセプト:
    - 上部にシンプルな時計
    - 縦一列のアプリリスト（アイコン＋テキスト）
    - 右端にアルファベットインデックス
    - 左下にブランド刻印
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    tools:context=".ui.HomeFragment">

    <!-- ロック用プレースホルダー -->
    <FrameLayout
        android:id="@+id/lock"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:contentDescription="@string/lock_layout_description" />

    <!-- 最近のアプリ用プレースホルダー -->
    <FrameLayout
        android:id="@+id/recents"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:contentDescription="@string/recents_layout_description" />

    <!-- ガラスエフェクト背景（画面全体をカバー）-->
    <eightbitlab.com.blurview.BlurView
        android:id="@+id/blurView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC0D0D14"
        android:visibility="gone" />

    <!-- メインコンテンツ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 上部スペーサー -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.12" />

        <!-- 日時エリア -->
        <LinearLayout
            android:id="@+id/dateTimeLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="28dp"
            android:layout_marginEnd="28dp"
            android:gravity="start"
            android:orientation="vertical"
            android:paddingVertical="8dp"
            android:paddingHorizontal="12dp"
            android:background="@drawable/glass_card"
            android:visibility="gone"
            tools:visibility="visible">

            <!-- 時計 -->
            <TextClock
                android:id="@+id/clock"
                style="@style/TextDefault"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-light"
                android:format12Hour="h:mm"
                android:format24Hour="H:mm"
                android:includeFontPadding="false"
                android:letterSpacing="-0.03"
                android:textSize="@dimen/time_size"
                tools:text="02:34" />

            <!-- 日付 -->
            <TextView
                android:id="@+id/date"
                style="@style/TextDefault"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:format12Hour="EEE, dd MMM"
                android:format24Hour="EEE, dd MMM"
                android:includeFontPadding="false"
                android:letterSpacing="0.05"
                android:paddingHorizontal="3dp"
                android:textSize="@dimen/date_size"
                tools:text="Thu, 30 Dec" />

        </LinearLayout>

        <!-- 時計とリストの間の余白 -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.04" />

        <!-- アプリリスト + アルファベットインデックス（重ね合わせ） -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="80dp">

            <!-- Niagara風 縦一列アプリリスト -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/niagaraRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:fadingEdgeLength="48dp"
                android:paddingEnd="32dp"
                android:paddingStart="16dp"
                android:requiresFadingEdge="vertical" />

            <!-- アルファベットインデックス（右端） -->
            <LinearLayout
                android:id="@+id/appIndex"
                android:layout_width="24dp"
                android:layout_height="match_parent"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="4dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="16dp"
                android:visibility="gone" />

        </FrameLayout>

    </LinearLayout>

    <!-- 初回起動時のヒント -->
    <TextView
        android:id="@+id/firstRunTips"
        style="@style/TextSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="88dp"
        android:text="@string/swipe_up_for_apps"
        android:visibility="gone"
        tools:visibility="visible" />

    <!-- デフォルトランチャー設定ボタン -->
    <TextView
        android:id="@+id/setDefaultLauncher"
        style="@style/TextMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="88dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/set_as_default_launcher_u"
        android:visibility="gone" />

    <!-- ブランド刻印 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="28dp"
        android:layout_marginBottom="36dp"
        android:orientation="vertical"
        android:alpha="0.45">

        <View
            android:layout_width="32dp"
            android:layout_height="1.5dp"
            android:layout_marginBottom="5dp"
            android:background="@drawable/brand_gradient" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.15"
            android:text="QALAUNCHER 0.0.1"
            android:textAllCaps="false"
            android:textColor="@color/qa_subtitle_color"
            android:textSize="9sp" />
    </LinearLayout>

</FrameLayout>
